{
  "manifest_version": 2,
  "name": "UTI Toolkit – MJardim",
  "version": "1.0.1",
  "description": "Calculadoras clínicas para UTI: ventilação mecânica, RSI, infusão, sódio/água livre e evolução clínica.",
  "author": "MJardim Serviços Médicos",
  "browser_specific_settings": {
    "gecko": {
      "id": "uti-toolkit@mjardim.med.br",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "icons": {
    "48":  "icons/icon-48.svg",
    "96":  "icons/icon-96.svg",
    "128": "icons/icon-128.svg"
  },
  "browser_action": {
    "default_title": "UTI Toolkit",
    "default_icon":  "icons/icon-48.svg"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "permissions": ["tabs"]
}
